{
  "compilerOptions": {
    /* Target & Module */
    "target": "ESNext",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2022"],
    
    /* Output & Structure */
    "outDir": "./dist",
    "rootDir": ".",
    
    /* Module Resolution */
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    
    /* Types */
    "types": ["node"],
    
    /* Path Aliases (Tanpa baseUrl) */
    "paths": {
      "@/*": ["./src/*"],
      "@generated/*": ["./generated/*"]
    },
    
    /* Strictness */
    "strict": true
  },
  
  "include": [
    "src/**/*",
    "generated/**/*",
    "*.config.ts",
    "*.config.js"
  ],
  
  "exclude": [
    "node_modules",
    "dist"
  ]
}
