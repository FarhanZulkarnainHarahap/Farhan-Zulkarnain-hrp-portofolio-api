{
  "compilerOptions": {
    "target": "ESNext",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ESNext"],
    
    /* Output & Structure */
    "outDir": "./dist",
    "rootDir": ".",
    
    /* Ganti baseUrl dengan ignoreDeprecations jika tetap ingin menggunakannya */
    /* Atau biarkan kosong karena NodeNext menangani resolusi modul secara berbeda */
    "ignoreDeprecations": "6.0", 
    
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    
    "types": ["node"],
    
    "paths": {
      "@/*": ["./src/*"],
      "@api/*": ["./api/*"],
      "@generated/*": ["./generated/*"]
    },
    
    "strict": true
  },
  
  "include": [
    "src/**/*",
    "api/**/*", 
    "generated/**/*",
    "*.config.ts",
    "app.ts"
  ],
  
  "exclude": [
    "node_modules",
    "dist"
  ]
}
